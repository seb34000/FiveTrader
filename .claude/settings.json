{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(*.go)",
      "Write(config/**)",
      "Write(feed/**)",
      "Write(oracle/**)",
      "Write(market/**)",
      "Write(strategy/**)",
      "Write(risk/**)",
      "Write(execution/**)",
      "Write(monitor/**)",
      "Write(go.mod)",
      "Write(go.sum)",
      "Write(.env.example)",
      "Write(README.md)",
      "Write(Makefile)",
      "Write(Dockerfile)",
      "Bash(go build ./...)",
      "Bash(go test ./...)",
      "Bash(go test ./... -v)",
      "Bash(go test ./... -run *)",
      "Bash(go run main.go --dry-run*)",
      "Bash(go vet ./...)",
      "Bash(go mod tidy)",
      "Bash(go mod download)",
      "Bash(gofmt -w *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *.go)",
      "Bash(git add go.*)",
      "Bash(git commit*)",
      "Bash(make *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.claude/settings.local.json)",
      "Write(.env)",
      "Bash(go run main.go --live*)",
      "Bash(rm -rf*)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write(**.go)",
        "hooks": [
          {
            "type": "command",
            "command": "cd $CLAUDE_PROJECT_DIR && go vet ./... 2>&1 | head -20 || true"
          }
        ]
      },
      {
        "matcher": "Write(**/strategy/*.go)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[WARN] Nouvelle stratégie modifiée — valider avec go test ./strategy/... avant usage live'"
          }
        ]
      }
    ]
  },
  "env": {
    "DRY_RUN": "true",
    "LOG_LEVEL": "debug",
    "GOFLAGS": "-race"
  }
}